#!/bin/bash

cleanup() {
  [[ -n $PID ]] && kill $PID 2>/dev/null
  rm -f "$TMPFILE"
}
trap cleanup EXIT

hyprpicker -r -z >/dev/null 2>&1 &
PID=$!
sleep .1
SELECTION=$(slurp 2>/dev/null)

[[ -z $SELECTION ]] && exit 0

TMPFILE=$(mktemp /tmp/ocr-XXXXXX.png)
grim -g "$SELECTION" "$TMPFILE" || exit 1

TEXT=$(ocrs "$TMPFILE" 2>/dev/null) || exit 1

[[ -z $TEXT ]] && exit 1

printf "%s" "$TEXT" | wl-copy
notify-send "OCR" "Copied text from selection to clipboard"

# vim: ft=sh
