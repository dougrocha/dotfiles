#!/bin/bash

WPCTL_OUTPUT=$(wpctl status)
DEFAULT_SINK=$(echo "$WPCTL_OUTPUT" | sed -n '/Settings/,/^$/p' | grep 'Audio/Sink' | awk '{print $NF}')
declare -a SINK_IDS SINK_NAMES OPTIONS

readarray -t SINKS < <(echo "$WPCTL_OUTPUT" | sed -n '/Sinks:/,/Sources:/p' | grep -E '^\s+│\s+[\*]?\s+[0-9]+\.' | sed 's/^[[:space:]│]*//' || true)

for sink in "${SINKS[@]}"; do
    [[ -z "$sink" ]] && continue
    [[ "$sink" =~ ^\* ]] && sink=$(echo "$sink" | sed 's/^\*[[:space:]]*//')

    SINK_ID=$(echo "$sink" | cut -d'.' -f1 | xargs)
    wpctl inspect "$SINK_ID" 2>/dev/null | grep -q 'media.class = "Audio/Sink/Internal"' && continue
    
    INSPECT=$(wpctl inspect "$SINK_ID" 2>/dev/null)
    NODE_NAME=$(echo "$INSPECT" | grep 'node.name = ' | cut -d'"' -f2)
    SINK_NAME=$(echo "$sink" | cut -d'.' -f2- | sed 's/\[vol:.*\]//' | xargs)
    
    PREFIX=""
    [[ "$NODE_NAME" == "$DEFAULT_SINK" ]] && PREFIX="✓ "
    
    SINK_IDS+=("$SINK_ID")
    SINK_NAMES+=("$SINK_NAME")
    OPTIONS+=("${PREFIX}${SINK_NAME}")
done

while IFS= read -r line; do
    if [[ "$line" =~ ^[[:space:]│\*]+([0-9]+)\.[[:space:]]+(.+)[[:space:]]+\[Audio/Sink\][[:space:]]*$ ]]; then
        FILTER_ID="${BASH_REMATCH[1]}"
        FILTER_NAME="${BASH_REMATCH[2]}"
        
        [[ " ${SINK_IDS[@]} " =~ " ${FILTER_ID} " ]] && continue

        INSPECT=$(wpctl inspect "${FILTER_ID}" 2>/dev/null)
        echo "$INSPECT" | grep -q 'media.class = "Audio/Sink/Internal"' && continue
        
        NODE_NAME=$(echo "$INSPECT" | grep 'node.name = ' | cut -d'"' -f2)
        DESC=$(echo "$INSPECT" | grep 'node.description = ' | cut -d'"' -f2)
        [[ -z "$DESC" ]] && DESC="$FILTER_NAME"
        
        PREFIX=""
        [[ "$NODE_NAME" == "$DEFAULT_SINK" ]] && PREFIX="✓ "

        SINK_IDS+=("$FILTER_ID")
        SINK_NAMES+=("$DESC")
        OPTIONS+=("${PREFIX}${DESC}")
    fi
done <<< "$WPCTL_OUTPUT"

[[ ${#SINK_IDS[@]} -eq 0 ]] && echo "No audio output devices found!" && exit 1

SELECTED=$(printf '%s\n' "${OPTIONS[@]}" | gum choose --header "Select audio output device")
[[ -z "$SELECTED" ]] && exit 0

for i in "${!OPTIONS[@]}"; do
    if [[ "${OPTIONS[$i]}" == "$SELECTED" ]]; then
        wpctl set-default "${SINK_IDS[$i]}" && echo "✓ Default audio device set to: ${SINK_NAMES[$i]}" || { echo "Failed to set default audio device!"; exit 1; }
        exit 0
    fi
done

# vim: ft=sh
