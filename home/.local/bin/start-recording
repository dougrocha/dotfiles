#!/bin/bash

TARGET="${1:-screen}" # "screen", "DP-1", "DP-2"
RECORDING_DIR="${HOME}/Videos"
mkdir -p "$RECORDING_DIR"

TIMESTAMP=$(date +%Y%m%d_%H%M%S)
OUTPUT_FILE="$RECORDING_DIR/recording_${TIMESTAMP}.mp4"

AUDIO_ARGS=(-a "default_output|default_input")
[[ "$*" == *"--no-audio"* ]] && AUDIO_ARGS=()

setsid gpu-screen-recorder -w "$TARGET" -f 60 -q high -c mp4 "${AUDIO_ARGS[@]}" -o "$OUTPUT_FILE" &>/dev/null &

notify-send "Recording Started" -t 3 -a "GPU Screen Recorder"

# vim: ft=sh
