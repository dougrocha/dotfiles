#!/bin/bash

[[ -f ~/.config/user-dirs.dirs ]] && source ~/.config/user-dirs.dirs
OUTPUT_DIR="${XDG_PICTURES_DIR:-$HOME/Pictures/}"

if [[ ! -d $OUTPUT_DIR ]]; then
  notify-send "Invalid directory" "Pictures directory does not exist: $OUTPUT_DIR" -a "Screenshot" -u critical -t 3
  exit 1
fi

pkill slurp && exit 0

DELAY=0
CURSOR=false
FREEZE=false
SLURP_THEME="-b #00000055 -c #9acbfaFF -B #00000055"
ARGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --delay) DELAY="$2"; shift 2 ;;
        --cursor) CURSOR=true; shift ;;
        --freeze) FREEZE=true; shift ;;
        *) ARGS+=("$1"); shift ;;
    esac
done
set -- "${ARGS[@]}"
MODE=${1:-}

JQ_MONITOR_GEO='
  def format_geo:
    .x as $x | .y as $y |
    (.width / .scale | floor) as $w |
    (.height / .scale | floor) as $h |
    .transform as $t |
    if $t == 1 or $t == 3 then
      "\($x),\($y) \($h)x\($w)"
    else
      "\($x),\($y) \($w)x\($h)"
    end;
'

get_visible_clients() {
  local monitors_json=$(hyprctl monitors -j)
  local visible_workspaces=$(echo "$monitors_json" | jq -r '
    [.[] | .activeWorkspace.id, (if .specialWorkspace.id != 0 then .specialWorkspace.id else empty end)] |
    unique | join(",")
  ')
  local clients_json=$(hyprctl clients -j)
  local fullscreen_workspaces=$(echo "$clients_json" | jq -r '[.[] | select(.fullscreen != 0) | .workspace.id] | unique | join(",")')
  echo "$clients_json" | jq -r --arg ws "$visible_workspaces" --arg fs_ws "$fullscreen_workspaces" '
    ($ws | split(",") | map(tonumber)) as $visible |
    ($fs_ws | if . == "" then [] else split(",") | map(tonumber) end) as $fullscreen_ws |
    .[] |
    select([.workspace.id] | inside($visible)) |
    .workspace.id as $wid |
    select(if ($fullscreen_ws | contains([$wid])) then .fullscreen != 0 else true end) |
    "\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])"'
}

get_rectangles() {
  local monitors_json=$(hyprctl monitors -j)
  echo "$monitors_json" | jq -r "${JQ_MONITOR_GEO} .[] | format_geo"
  get_visible_clients
}

save() {
  local selection="$1"
  [[ -z $selection ]] && exit 0

  FILENAME="Screenshot-$(date +'%Y-%m-%d-at-%I.%M.%S%p').png"
  FILEPATH="$OUTPUT_DIR/Screenshots/$FILENAME"
  mkdir -p "$OUTPUT_DIR/Screenshots"

  GRIM_ARGS=(-g "$selection")
  [[ "$CURSOR" == "true" ]] && GRIM_ARGS+=(-c)
  grim "${GRIM_ARGS[@]}" "$FILEPATH" || exit 1
  wl-copy <"$FILEPATH"
  notify-send "Screenshot captured" "Saved to clipboard and file" -a "Screenshot" -t 10 -i "$FILEPATH"
}

grab() {
  local mode="$1"
  local selection

  if [[ $FREEZE == true ]]; then
    hyprpicker -r -z >/dev/null 2>&1 &
    FREEZE_PID=$!
    sleep .1
  fi

  case "$mode" in
    region)
      selection=$(slurp $SLURP_THEME 2>/dev/null)
      ;;
    windows)
      selection=$(get_visible_clients | slurp -r $SLURP_THEME 2>/dev/null)
      if [[ -n $selection && $DELAY -gt 0 ]]; then
        WIN_ADDR=$(hyprctl clients -j | jq -r --arg geo "$selection" \
          '.[] | select("\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])" == $geo) | .address' | head -1)
      fi
      ;;
    fullscreen)
      selection=$(hyprctl monitors -j | jq -r "${JQ_MONITOR_GEO} .[] | select(.focused == true) | format_geo")
      ;;
    smart|*)
      RECTS=$(get_rectangles)
      selection=$(echo "$RECTS" | slurp $SLURP_THEME 2>/dev/null)

      if [[ $selection =~ ^([0-9]+),([0-9]+)[[:space:]]([0-9]+)x([0-9]+)$ ]]; then
        if ((${BASH_REMATCH[3]} * ${BASH_REMATCH[4]} < 20)); then
          click_x="${BASH_REMATCH[1]}"
          click_y="${BASH_REMATCH[2]}"
          while IFS= read -r rect; do
            if [[ $rect =~ ^([0-9]+),([0-9]+)[[:space:]]([0-9]+)x([0-9]+) ]]; then
              rx="${BASH_REMATCH[1]}" ry="${BASH_REMATCH[2]}" rw="${BASH_REMATCH[3]}" rh="${BASH_REMATCH[4]}"
              if ((click_x >= rx && click_x < rx + rw && click_y >= ry && click_y < ry + rh)); then
                selection="${rx},${ry} ${rw}x${rh}"
                break
              fi
            fi
          done <<<"$RECTS"
        fi
      fi
      ;;
  esac

  [[ -n $FREEZE_PID ]] && kill $FREEZE_PID 2>/dev/null
  [[ $DELAY -gt 0 ]] && sleep "$DELAY"
  if [[ -n ${WIN_ADDR:-} ]]; then
    selection=$(hyprctl clients -j | jq -r --arg addr "$WIN_ADDR" \
      '.[] | select(.address == $addr) | "\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])"')
  fi
  save "$selection"
}

grab "$MODE" &
wait

# vim: ft=sh
