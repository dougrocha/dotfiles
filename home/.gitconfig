[user]
    name = Douglas Rocha
    email = 79188161+dougrocha@users.noreply.github.com
    signingkey = ~/.ssh/id_ed25519
[pull]
    rebase = true
[commit]
    gpgsign = true
[gpg]
    format = ssh
[tag]
    gpgsign = true
[column]
    ui = auto
[branch]
    sort = -committerdate
[init]
    defaultBranch = main
[difftool "nvim_difftool"]
    cmd = nvim -c \"packadd nvim.difftool\" -d \"$LOCAL\" \"$REMOTE\"
[diff]
    algorithm = histogram
    mnemonicPrefix = true
    renames = true
    colorMoved = true
    tool = nvim_difftool
[push]
    autoSetupRemote = true
[fetch]
    prune = true
[rerere]
    enabled = true
    autoupdate = true
[core]
    editor = nvim
